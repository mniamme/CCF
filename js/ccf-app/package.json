{
  "name": "@microsoft/ccf-app",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/ccf"
  },
  "version": "0.0.0",
  "description": "CCF app support package",
  "main": "index.js",
  "files": [
    "*.js",
    "*.d.ts"
  ],
  "type": "module",
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "pretest": "node -e \"require('node:fs').rmSync('.test', { recursive: true, force: true })\"",
    "test": "tsc -p test/tsconfig.json && node --test .test/test/*.test.js",
    "posttest": "node -e \"require('node:fs').rmSync('.test', { recursive: true, force: true })\"",
    "docs": "typedoc",
    "docs:watch": "rm -rf html && typedoc --watch --preserveWatchOutput"
  },
  "author": "Microsoft",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/node-forge": "^1.0.0",
    "node-forge": "^1.2.0",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2"
  },
  "bin": {
    "ccf-build-bundle": "scripts/build_bundle.js"
  }
}
